# ─── CFP Conference Knowledge Pipeline — environment variables ──────────────
# Copy to .env and edit. .env is gitignored; .env.example is committed.
#
# Every variable here is read by config.py via os.getenv(). Defaults shown
# match config.py — override only what you need.

# ─── Machine profile ─────────────────────────────────────────────────────────
# Controls which Ollama model tiers run locally. Tiers whose models are
# absent from this profile escalate to wcfp:escalate:tier4 for the next
# capable machine. See context.md §2 for the full hardware matrix.
# Options: dgx | gpu_large | gpu_mid | gpu_small | cpu_only
WCFP_MACHINE=gpu_mid

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Source-of-truth store. Source DSN includes db, user, password, host, port.
PG_DSN=postgresql://wcfp:wcfp@localhost:5432/wikicfp

# ─── Redis ───────────────────────────────────────────────────────────────────
# Queue + per-domain rate limiting + dedup cache. Owns NO business data.
REDIS_URL=redis://localhost:6379/0

# ─── Ollama — single local daemon ───────────────────────────────────────────
# All LLM calls go here. There is no per-model host routing.
OLLAMA_HOST=http://localhost:11434

# ─── Google Cloud Storage (off-machine persistence) ─────────────────────────
# pg_dump and Parquet snapshots sync here between sessions.
GCS_BUCKET=wcfp-data
GCS_PREFIX=prod
RCLONE_REMOTE=gcs

# ─── Scraper identity ────────────────────────────────────────────────────────
# Put a contactable email in the User-Agent so site admins can reach you
# before they IP-block the scraper. context.md §15 / arch.md §2 R2.
USER_AGENT=cfp-scraper/1.0 (+your@email.com)
